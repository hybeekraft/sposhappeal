{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1", "headers": { "Cache-Control": "public, max-age=86400" } },
    { "src": "/booking.html", "dest": "/frontend/booking.html" },
    { "src": "/privacy.html", "dest": "/frontend/privacy.html" },
    { "src": "/staff.html", "dest": "/frontend/staff.html" },
    { "src": "/404.html", "dest": "/frontend/404.html" },
    { "src": "/robots.txt", "dest": "/frontend/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/frontend/sitemap.xml" },
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/(.*)", "dest": "/frontend/404.html", "status": 404 }
  ]
}
