# Port for running the local server
PORT=5000

# MongoDB URI (MongoDB Atlas or Local MongoDB connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/sposh_appeal?retryWrites=true&w=majority

# Paystack Secrets (obtain from Paystack Dashboard Settings -> API Keys & Webhooks)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=secret_webhook_xxxxxxxxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=https://sposh-appeal.vercel.app/booking.html
ADMIN_PASSWORD=change_me_to_a_long_random_string
STAFF_PASSWORD=change_me_to_a_different_long_random_string

# SMTP Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=S'posh APPEAL <noreply@sposhappeal.com>
ADMIN_EMAIL=admin_recipient@example.com

# Twilio WhatsApp configuration
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=+2348012345678